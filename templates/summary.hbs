          <button onclick="pagerAction('images-table','next')">›</button>
          <button onclick="pagerAction('images-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper">
        <table id="images-table">
          <thead>
            <tr>
              <th onclick="sortTable('images-table', 0)">Page</th>
              <th onclick="sortTable('images-table', 1)">Image URL</th>
              <th onclick="sortTable('images-table', 2)">Alt Text</th>
              <th onclick="sortTable('images-table', 3)">Has Alt</th>
            </tr>
          </thead>
          <tbody id="images-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Performance Tab -->
    <div id="tab-performance" class="tab-content">
      <h2>Performance Overview</h2>

      <!-- Performance Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Fast Pages (&lt;1s)</div>
          <div class="stat-value">{{fastPages}}</div>
        </div>
        <div class="stat-card {{#if (gt moderatePages 0)}}warning{{/if}}">
          <div class="stat-label">Moderate (1-3s)</div>
          <div class="stat-value">{{moderatePages}}</div>
        </div>
        <div class="stat-card {{#if (gt slowPages 0)}}critical{{/if}}">
          <div class="stat-label">Slow Pages (&gt;3s)</div>
          <div class="stat-value">{{slowPages}}</div>
        </div>
        <div class="stat-card {{#if (gt issuesSummary.redirectChains 0)}}warning{{/if}}">
          <div class="stat-label">Pages with Redirects</div>
          <div class="stat-value">{{issuesSummary.redirectChains}}</div>
        </div>
      </div>

      <!-- Performance Visualizations -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 16px; margin: 16px 0;">
        <!-- Response Time Distribution Chart -->
        <div style="background: white; padding: 16px; border-radius: 4px; border: 1px solid #e0e0e0;">
          <h3 style="margin: 0 0 12px 0; font-size: 14px;">Response Time Distribution</h3>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="width: 120px; font-size: 12px;">Fast (&lt;1s)</span>
              <div style="flex: 1; background: #f0f0f0; height: 24px; border-radius: 2px; overflow: hidden;">
                <div style="background: #28a745; height: 100%; width: {{percentage fastPages totalPages}}%;"></div>
              </div>
              <span style="font-weight: 600; font-size: 12px; min-width: 40px; text-align: right;">{{fastPages}}</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="width: 120px; font-size: 12px;">Moderate (1-3s)</span>
              <div style="flex: 1; background: #f0f0f0; height: 24px; border-radius: 2px; overflow: hidden;">
                <div style="background: #ffc107; height: 100%; width: {{percentage moderatePages totalPages}}%;"></div>
              </div>
              <span style="font-weight: 600; font-size: 12px; min-width: 40px; text-align: right;">{{moderatePages}}</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="width: 120px; font-size: 12px;">Slow (&gt;3s)</span>
              <div style="flex: 1; background: #f0f0f0; height: 24px; border-radius: 2px; overflow: hidden;">
                <div style="background: #dc3545; height: 100%; width: {{percentage slowPages totalPages}}%;"></div>
              </div>
              <span style="font-weight: 600; font-size: 12px; min-width: 40px; text-align: right;">{{slowPages}}</span>
            </div>
          </div>
        </div>

        <!-- Content Size Distribution -->
        <div style="background: white; padding: 16px; border-radius: 4px; border: 1px solid #e0e0e0;">
          <h3 style="margin: 0 0 12px 0; font-size: 14px;">Content Quality Distribution</h3>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="width: 120px; font-size: 12px;">Good (&gt;300w)</span>
              <div style="flex: 1; background: #f0f0f0; height: 24px; border-radius: 2px; overflow: hidden;">
                <div style="background: #28a745; height: 100%; width: {{percentage goodContentPages totalPages}}%;"></div>
              </div>
              <span
                style="font-weight: 600; font-size: 12px; min-width: 40px; text-align: right;">{{goodContentPages}}</span>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="width: 120px; font-size: 12px;">Thin (&lt;300w)</span>
              <div style="flex: 1; background: #f0f0f0; height: 24px; border-radius: 2px; overflow: hidden;">
                <div style="background: #ffc107; height: 100%; width: {{percentage thinContentPages totalPages}}%;"></div>
              </div>
              <span
                style="font-weight: 600; font-size: 12px; min-width: 40px; text-align: right;">{{thinContentPages}}</span>
            </div>
          </div>
        </div>
      </div>

      <h2 style="margin-top: 24px;">Response Times & Metrics</h2>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search pages..."
          onkeyup="filterTable('performance-table', this.value)">
        <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
          <select id="performance-table-pageSize" onchange="changePageSize('performance-table', this.value)">
            <option>25</option>
            <option selected>100</option>
            <option>250</option>
            <option>500</option>
          </select>
        </label>
        <div id="performance-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
          <button onclick="pagerAction('performance-table','first')">«</button>
          <button onclick="pagerAction('performance-table','prev')">‹</button>
          <span id="performance-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
          <button onclick="pagerAction('performance-table','next')">›</button>
          <button onclick="pagerAction('performance-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper">
        <table id="performance-table">
          <thead>
            <tr>
              <th onclick="sortTable('performance-table', 0)">URL</th>
              <th onclick="sortTable('performance-table', 1)">Response (ms)</th>
              <th onclick="sortTable('performance-table', 2)">Redirects</th>
              <th onclick="sortTable('performance-table', 3)">Word Count</th>
              <th onclick="sortTable('performance-table', 4)">HTML Size</th>
              <th onclick="sortTable('performance-table', 5)">Links</th>
              <th onclick="sortTable('performance-table', 6)">Images</th>
            </tr>
          </thead>
          <tbody id="performance-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- External Scripts Tab -->
    <div id="tab-scripts" class="tab-content">
      <h2>Scripts ({{externalScripts.length}} unique)</h2>
      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">All JavaScript files loaded via &lt;script src="..."&gt;
        tags in the static HTML.</p>

      {{#if externalScripts.length}}
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search scripts..."
          onkeyup="filterTable('scripts-table', this.value)">
      </div>
      <div class="table-wrapper">
        <table id="scripts-table">
          <thead>
            <tr>
              <th onclick="sortTable('scripts-table', 0)">Script URL</th>
              <th onclick="sortTable('scripts-table', 1)">Source</th>
              <th onclick="sortTable('scripts-table', 2)">Pages</th>
              <th onclick="sortTable('scripts-table', 3)">Async</th>
              <th onclick="sortTable('scripts-table', 4)">Defer</th>
              <th onclick="sortTable('scripts-table', 5)">Type</th>
            </tr>
          </thead>
          <tbody>
            {{#each externalScripts}}
            <tr>
              <td class="url-cell" title="{{this.src}}"><a href="{{this.src}}" class="url-link" target="_blank"
                  rel="noopener">{{truncateUrl this.src 80}}</a></td>
              <td class="no-wrap">{{#if this.isExternal}}<span class="badge badge-warning">Third-Party</span>{{else}}<span
                  class="badge badge-success">Same-Domain</span>{{/if}}</td>
              <td class="no-wrap"><span class="badge badge-info">{{this.count}}</span></td>
              <td class="no-wrap">{{#if this.async}}<span class="badge badge-success">Yes</span>{{else}}<span
                  class="badge badge-warning">No</span>{{/if}}</td>
              <td class="no-wrap">{{#if this.defer}}<span class="badge badge-success">Yes</span>{{else}}<span
                  class="badge badge-warning">No</span>{{/if}}</td>
              <td class="no-wrap">{{#if this.type}}{{this.type}}{{else}}<span style="color: #999;">default</span>{{/if}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <h2 style="margin-top: 24px;">Script Details by Page</h2>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search..."
          onkeyup="filterTable('scripts-by-page-table', this.value)">
      </div>
      <div class="table-wrapper">
        <table id="scripts-by-page-table">
          <thead>
            <tr>
              <th onclick="sortTable('scripts-by-page-table', 0)">Page</th>
              <th onclick="sortTable('scripts-by-page-table', 1)">Script Count</th>
              <th onclick="sortTable('scripts-by-page-table', 2)">Scripts</th>
            </tr>
          </thead>
          <tbody id="scripts-by-page-table-body"></tbody>
        </table>
      </div>
      {{else}}
      <div style="padding: 40px; text-align: center; background: #f8f9fa; border-radius: 8px; margin: 20px 0;">
        <p style="font-size: 16px; color: #666; margin: 0;">ℹ️ <strong>No scripts with src attributes found</strong></p>
        <p style="font-size: 14px; color: #666; margin-top: 12px;">This site may use only inline JavaScript or load scripts
          dynamically.</p>
        <p style="font-size: 13px; color: #999; margin-top: 8px; max-width: 600px; margin-left: auto; margin-right: auto;">
          <strong>Note:</strong> This crawler analyzes static HTML only. If this is a client-side rendered app,
          additional scripts may be loaded dynamically by JavaScript after page load.
          Check your browser's DevTools Network tab to see all runtime-loaded scripts.
        </p>
      </div>
      {{/if}}
    </div>

    <!-- Sitemap Tab -->
    <div id="tab-sitemap" class="tab-content">
      <h2>Sitemap Analysis</h2>

      {{#if sitemapInfo}}
      <!-- Sitemap Stats -->
      <div class="stats-grid" style="margin-bottom: 20px;">
        <div class="stat-card">
          <div class="stat-label">URLs in Sitemap</div>
          <div class="stat-value">{{sitemapInfo.sitemapUrlCount}}</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">URLs Crawled</div>
          <div class="stat-value">{{totalPages}}</div>
        </div>
        <div class="stat-card {{#if sitemapInfo.urlsNotInSitemap.length}}warning{{/if}}">
          <div class="stat-label">Not in Sitemap</div>
          <div class="stat-value">{{sitemapInfo.urlsNotInSitemap.length}}</div>
          <div class="stat-detail">Crawled but missing from sitemap</div>
        </div>
        <div class="stat-card {{#if sitemapInfo.orphanUrls.length}}warning{{/if}}">
          <div class="stat-label">Orphan URLs</div>
          <div class="stat-value">{{sitemapInfo.orphanUrls.length}}</div>
          <div class="stat-detail">In sitemap but not crawled</div>
        </div>
        <div class="stat-card {{#if sitemapInfo.nonIndexableInSitemap.length}}critical{{/if}}">
          <div class="stat-label">Non-Indexable in Sitemap</div>
          <div class="stat-value">{{sitemapInfo.nonIndexableInSitemap.length}}</div>
          <div class="stat-detail">Noindex or error pages in sitemap</div>
        </div>
      </div>

      <!-- Sitemap Source -->
      <div style="background: #f8f9fa; padding: 12px; border-radius: 4px; margin-bottom: 20px;">
        <strong>Sitemap Location{{#if (gt sitemapInfo.sitemapUrls.length 1)}}s{{/if}}:</strong>
        {{#each sitemapInfo.sitemapUrls}}
        <div style="margin-top: 4px; font-family: monospace; font-size: 11px;">
          <a href="{{this}}" target="_blank" rel="noopener" style="color: #0066cc;">{{this}}</a>
        </div>
        {{/each}}
      </div>

      {{#if sitemapInfo.urlsNotInSitemap.length}}
      <!-- URLs Not in Sitemap -->
      <h3 style="color: #ffc107;">⚠️ Crawled URLs Not in Sitemap ({{sitemapInfo.urlsNotInSitemap.length}})</h3>
      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">These pages were crawled but are missing from your
        sitemap. Consider adding them.</p>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search URLs..."
          onkeyup="filterTable('not-in-sitemap-table', this.value)">
        <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
          <select id="not-in-sitemap-table-pageSize" onchange="changePageSize('not-in-sitemap-table', this.value)">
            <option>25</option>
            <option selected>100</option>
            <option>250</option>
            <option>500</option>
          </select>
        </label>
        <div id="not-in-sitemap-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
          <button onclick="pagerAction('not-in-sitemap-table','first')">«</button>
          <button onclick="pagerAction('not-in-sitemap-table','prev')">‹</button>
          <span id="not-in-sitemap-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
          <button onclick="pagerAction('not-in-sitemap-table','next')">›</button>
          <button onclick="pagerAction('not-in-sitemap-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper" style="margin-bottom: 24px;">
        <table id="not-in-sitemap-table">
          <thead>
            <tr>
              <th onclick="sortTable('not-in-sitemap-table', 0)">URL</th>
              <th onclick="sortTable('not-in-sitemap-table', 1)">Status</th>
              <th onclick="sortTable('not-in-sitemap-table', 2)">Indexable</th>
            </tr>
          </thead>
          <tbody id="not-in-sitemap-table-body"></tbody>
        </table>
      </div>
      {{/if}}

      {{#if sitemapInfo.orphanUrls.length}}
      <!-- Orphan URLs (in sitemap but not crawled) -->
      <h3 style="color: #ffc107;">⚠️ Orphan URLs in Sitemap ({{sitemapInfo.orphanUrls.length}})</h3>
      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">These URLs are in your sitemap but were not discovered
        during the crawl. They may be orphaned (no internal links).</p>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search URLs..."
          onkeyup="filterTable('orphan-urls-table', this.value)">
        <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
          <select id="orphan-urls-table-pageSize" onchange="changePageSize('orphan-urls-table', this.value)">
            <option>25</option>
            <option selected>100</option>
            <option>250</option>
            <option>500</option>
          </select>
        </label>
        <div id="orphan-urls-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
          <button onclick="pagerAction('orphan-urls-table','first')">«</button>
          <button onclick="pagerAction('orphan-urls-table','prev')">‹</button>
          <span id="orphan-urls-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
          <button onclick="pagerAction('orphan-urls-table','next')">›</button>
          <button onclick="pagerAction('orphan-urls-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper" style="margin-bottom: 24px;">
        <table id="orphan-urls-table">
          <thead>
            <tr>
              <th onclick="sortTable('orphan-urls-table', 0)">URL</th>
            </tr>
          </thead>
          <tbody id="orphan-urls-table-body"></tbody>
        </table>
      </div>
      {{/if}}

      {{#if sitemapInfo.nonIndexableInSitemap.length}}
      <!-- Non-indexable URLs in Sitemap -->
      <h3 style="color: #dc3545;">❌ Non-Indexable URLs in Sitemap ({{sitemapInfo.nonIndexableInSitemap.length}})</h3>
      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">These URLs are in your sitemap but shouldn't be (noindex,
        404, or error status). Remove them from the sitemap.</p>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search URLs..."
          onkeyup="filterTable('non-indexable-sitemap-table', this.value)">
        <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
          <select id="non-indexable-sitemap-table-pageSize"
            onchange="changePageSize('non-indexable-sitemap-table', this.value)">
            <option>25</option>
            <option selected>100</option>
            <option>250</option>
            <option>500</option>
          </select>
        </label>
        <div id="non-indexable-sitemap-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
          <button onclick="pagerAction('non-indexable-sitemap-table','first')">«</button>
          <button onclick="pagerAction('non-indexable-sitemap-table','prev')">‹</button>
          <span id="non-indexable-sitemap-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
          <button onclick="pagerAction('non-indexable-sitemap-table','next')">›</button>
          <button onclick="pagerAction('non-indexable-sitemap-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper">
        <table id="non-indexable-sitemap-table">
          <thead>
            <tr>
              <th onclick="sortTable('non-indexable-sitemap-table', 0)">URL</th>
              <th onclick="sortTable('non-indexable-sitemap-table', 1)">Issue</th>
            </tr>
          </thead>
          <tbody id="non-indexable-sitemap-table-body"></tbody>
        </table>
      </div>
      {{/if}}

      {{else}}
      <div style="padding: 40px; text-align: center; color: #999;">
        <h3 style="color: #666; margin-bottom: 12px;">No Sitemap Found</h3>
        <p>Could not detect a sitemap at common locations (/sitemap.xml, from robots.txt).</p>
        <p style="margin-top: 8px; font-size: 12px;">Use <code>--sitemap-url</code> to specify a custom sitemap location.</p>
      </div>
      {{/if}}
    </div>

    <!-- 404 Pages Tab -->
    <div id="tab-404s" class="tab-content">
      <h2>404 Pages ({{issuesSummary.brokenLinks}})</h2>

      <div class="stats-grid" style="margin-bottom: 20px;">
        <div class="stat-card critical">
          <div class="stat-label">Total 404 Pages</div>
          <div class="stat-value">{{issuesSummary.brokenLinks}}</div>
        </div>
      </div>

      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">These pages returned a 404 Not Found status. Use the
        referrers to identify which pages need to be fixed.</p>
      <div class="table-controls">
        <input type="text" class="search-box" placeholder="Search 404 pages..."
          onkeyup="filterTable('pages404-table', this.value)">
        <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
          <select id="pages404-table-pageSize" onchange="changePageSize('pages404-table', this.value)">
            <option>25</option>
            <option selected>100</option>
            <option>250</option>
            <option>500</option>
          </select>
        </label>
        <div id="pages404-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
          <button onclick="pagerAction('pages404-table','first')">«</button>
          <button onclick="pagerAction('pages404-table','prev')">‹</button>
          <span id="pages404-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
          <button onclick="pagerAction('pages404-table','next')">›</button>
          <button onclick="pagerAction('pages404-table','last')">»</button>
        </div>
      </div>
      <div class="table-wrapper">
        <table id="pages404-table">
          <thead>
            <tr>
              <th onclick="sortTable('pages404-table', 0)">404 URL</th>
              <th onclick="sortTable('pages404-table', 1)">Referrers</th>
              <th onclick="sortTable('pages404-table', 2)">Referring Pages</th>
            </tr>
          </thead>
          <tbody id="pages404-table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Issues Tab -->
    <div id="tab-issues" class="tab-content">
      <h2>Issues</h2>

      <!-- Sub-tabs for issues view -->
      <div class="subtabs" style="display:flex; gap:8px; margin:6px 0 12px 0;">
        <button class="tab active" data-subtab="issues-list" onclick="window.toggleIssuesView && toggleIssuesView('list')">All</button>
        <button class="tab" data-subtab="issues-types" onclick="window.toggleIssuesView && toggleIssuesView('types')">By Type</button>
      </div>

      <div id="issues-list-view">
        <!-- Issue stats by severity -->
        <div class="stats-grid" style="margin-bottom: 12px;">
          <div class="stat-card critical">
            <div class="stat-label">🔴 High Severity</div>
            <div class="stat-value">{{totalHighSeverity}}</div>
            <div class="stat-detail">Critical issues requiring immediate attention</div>
          </div>
          <div class="stat-card warning">
            <div class="stat-label">🟡 Medium Severity</div>
            <div class="stat-value">{{totalMediumSeverity}}</div>
            <div class="stat-detail">Important issues to address soon</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">🔵 Low Severity</div>
            <div class="stat-value">{{totalLowSeverity}}</div>
            <div class="stat-detail">Minor improvements and optimizations</div>
          </div>
        </div>

        <!-- Unified Issues Table with Severity and Type Filters -->
        <div class="table-controls">
          <label class="no-wrap" style="font-size: 12px; color: #666; margin-right: 10px;">Filter by severity:
            <select id="issues-severity-filter" onchange="filterIssuesBySeverity(this.value)">
              <option value="all">All Severities</option>
              <option value="high" selected>High Only</option>
              <option value="medium">Medium Only</option>
              <option value="low">Low Only</option>
            </select>
          </label>
          <label class="no-wrap" style="font-size: 12px; color: #666; margin-right: 10px;">Filter by issue:
            <select id="issues-type-filter"
              onchange="window.__SEO_ISSUE_TYPE_FILTER_HOOK__ && __SEO_ISSUE_TYPE_FILTER_HOOK__(this.value)">
              <option value="all" selected>All Issue Types</option>
              <!-- dynamic options populated by report.js -->
            </select>
          </label>
          <input type="text" class="search-box" placeholder="Search issues..."
            onkeyup="filterTable('issues-table', this.value)">
          <label class="no-wrap" style="font-size: 12px; color: #666;">Rows per page:
            <select id="issues-table-pageSize" onchange="changePageSize('issues-table', this.value)">
              <option>25</option>
              <option>50</option>
              <option selected>100</option>
              <option>250</option>
              <option>500</option>
            </select>
          </label>
          <div id="issues-table-pager" class="no-wrap" style="display: flex; gap: 6px; align-items: center;">
            <button onclick="pagerAction('issues-table','first')">«</button>
            <button onclick="pagerAction('issues-table','prev')">‹</button>
            <span id="issues-table-pageInfo" style="font-size: 12px; color: #666;">Page 1</span>
            <button onclick="pagerAction('issues-table','next')">›</button>
            <button onclick="pagerAction('issues-table','last')">»</button>
          </div>
        </div>

        <!-- Live totals for current filters -->
        <div id="issues-filter-summary" style="font-size:12px;color:#666;margin:4px 0 8px 0;">
          <!-- populated by report.js -->
        </div>

        <div class="table-wrapper">
          <table id="issues-table">
            <thead>
              <tr>
                <th onclick="sortTable('issues-table', 0)">Page</th>
                <th onclick="sortTable('issues-table', 1)">Severity</th>
                <th onclick="sortTable('issues-table', 2)">Issue</th>
              </tr>
            </thead>
            <tbody id="issues-table-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Issues by Type view -->
      <div id="issues-by-type-view" style="display:none;">
        <div class="table-wrapper">
          <table id="issues-type-table">
            <thead>
              <tr>
                <th onclick="sortTable('issues-type-table', 0)">Issue Type</th>
                <th onclick="sortTable('issues-type-table', 1)">Total</th>
                <th onclick="sortTable('issues-type-table', 2)">High</th>
                <th onclick="sortTable('issues-type-table', 3)">Medium</th>
                <th onclick="sortTable('issues-type-table', 4)">Low</th>
              </tr>
            </thead>
            <tbody id="issues-type-table-body"></tbody>
          </table>
        </div>
        <div style="font-size:12px;color:#666;margin-top:8px;">Click a row to view affected pages. </div>
      </div>
    </div>

    <div id="tab-api" class="tab-content">
      <h2>JSON API</h2>
      <p style="font-size: 12px; color: #666; margin-bottom: 16px;">All report data is exported as static JSON files for
        programmatic use.</p>

      <div class="stats-grid" style="margin-bottom: 12px;">
        <div class="stat-card">
          <div class="stat-label">Directory</div>
          <div class="stat-value">json/</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Pages</div>
          <div class="stat-value">json/pages/</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Issues</div>
          <div class="stat-value">json/issues/</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Index</div>
          <div class="stat-value">json/url-index.json</div>
        </div>
      </div>

      <h3>Endpoints</h3>
      <div
        style="background: #f8f9fa; padding: 12px; border-radius: 4px; border: 1px solid #e0e0e0; font-family: monospace; font-size: 12px;">
        <div><strong>Per Page:</strong> json/pages/{filename}.json</div>
        <div><strong>Per Page Issues:</strong> json/issues/{filename}.json</div>
        <div><strong>All Pages:</strong> json/all-pages.json</div>
        <div><strong>All Issues:</strong> json/all-issues.json</div>
        <div><strong>Issues Summary:</strong> json/issues-summary.json</div>
        <div><strong>Links:</strong> json/links.json</div>
        <div><strong>Headings:</strong> json/headings.json</div>
        <div><strong>Images:</strong> json/images.json</div>
        <div><strong>Performance:</strong> json/performance.json</div>
        <div><strong>External Scripts:</strong> json/external-scripts.json</div>
        <div><strong>404 Pages:</strong> json/404-pages.json</div>
        <div><strong>Sitemap Info:</strong> json/sitemap-info.json</div>
        <div><strong>Site Structure:</strong> json/site-structure.json</div>
        <div><strong>URL Index:</strong> json/url-index.json</div>
      </div>

      <h3 style="margin-top: 16px;">Usage</h3>
      <div style="background: #f8f9fa; padding: 12px; border-radius: 4px; border: 1px solid #e0e0e0;">
        <div style="font-family: monospace; font-size: 12px;">
          <div><em>Shell</em></div>
          <pre style="white-space: pre-wrap; margin-top: 8px;">curl ./json/all-issues.json | jq '.'
curl ./json/pages/index.json | jq '.title, .issuesCount'</pre>
          <div style="margin-top: 10px;"><em>JavaScript</em></div>
          <pre style="white-space: pre-wrap; margin-top: 8px;">fetch('./json/all-pages.json')
  .then(r => r.json())
  .then(data => console.log(data.pages.length));</pre>
        </div>
        <p style="font-size: 12px; color: #666; margin-top: 8px;">Use <code>json/url-index.json</code> to map full URLs to
          filenames in <code>json/pages/</code>.</p>
      </div>
    </div>
  </div>



  {{{manifestScript}}}
  <script src="report.js" defer></script>

  <script>
    // Tab switching
    function showTab(tabName) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
      var tabEl = document.getElementById('tab-' + tabName);
      if (tabEl) tabEl.classList.add('active');
      var btn = document.querySelector('.tab[data-tab="' + tabName + '"]');
      if (btn) btn.classList.add('active');
      if (window.__SEO_TAB_HOOK__) {
        try { window.__SEO_TAB_HOOK__(tabName); } catch (e) { }
      }
    }

    // Table sorting with proper type detection
    let sortStates = {};

    function sortTable(tableId, columnIndex) {
      if (window.__SEO_SORT_HOOK__) {
        const handled = window.__SEO_SORT_HOOK__(tableId, columnIndex);
        if (handled) return;
      }
      const table = document.getElementById(tableId);
      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr')).filter(row => row.style.display !== 'none');

      const key = tableId + '-' + columnIndex;
      if (!sortStates[key]) sortStates[key] = 'none';

      sortStates[key] = sortStates[key] === 'asc' ? 'desc' : 'asc';
      const direction = sortStates[key];

      // Update header indicators
      const headers = table.querySelectorAll('th');
      headers.forEach((h, i) => {
        h.classList.remove('sort-asc', 'sort-desc');
        if (i === columnIndex) h.classList.add('sort-' + direction);
      });

      // Sort rows
      rows.sort((a, b) => {
        let aText = a.cells[columnIndex].textContent.trim();
        let bText = b.cells[columnIndex].textContent.trim();

        // Try to parse as numbers
        const aNum = parseFloat(aText.replace(/[^0-9.-]/g, ''));
        const bNum = parseFloat(bText.replace(/[^0-9.-]/g, ''));

        if (!isNaN(aNum) && !isNaN(bNum)) {
          return direction === 'asc' ? aNum - bNum : bNum - aNum;
        }

        // String comparison
        return direction === 'asc' ? aText.localeCompare(bText) : bText.localeCompare(aText);
      });

      // Re-append all rows (including hidden ones)
      const allRows = Array.from(tbody.querySelectorAll('tr'));
      allRows.forEach(row => row.remove());
      rows.forEach(row => tbody.appendChild(row));
      allRows.filter(row => !rows.includes(row)).forEach(row => tbody.appendChild(row));
    }

    // Table filtering
    function filterTable(tableId, searchTerm) {
      if (window.__SEO_FILTER_HOOK__) {
        const handled = window.__SEO_FILTER_HOOK__(tableId, searchTerm);
        if (handled) return;
      }
      const table = document.getElementById(tableId);
      const tbody = table.querySelector('tbody');
      const rows = tbody.querySelectorAll('tr');
      const term = searchTerm.toLowerCase();

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(term) ? '' : 'none';
      });
    }

    function changePageSize(tableId, value) {
      if (window.__SEO_PAGESIZE_HOOK__) {
        window.__SEO_PAGESIZE_HOOK__(tableId, parseInt(value, 10) || 25);
      }
    }

    function pagerAction(tableId, action) {
      if (window.__SEO_PAGER_HOOK__) {
        window.__SEO_PAGER_HOOK__(tableId, action);
      }
    }

    // Initialize chunked tables when report.js is loaded
    window.addEventListener('DOMContentLoaded', function () {
      if (window.initReport) {
        window.initReport();
      }
    });
  </script>
</body>

</html>